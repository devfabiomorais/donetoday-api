generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum HistoryMode {
  BY_EXERCISE
  BY_ROUTINE
}

enum MetricType {
  REPS
  WEIGHT_REPS
  TIME
  WEIGHT_TIME
  WEIGHT_REPS_TIME
}

enum SetType {
  NORMAL
  WARMUP
  FEEDER
  DROPSET
  FAILURE
  CLUSTER_SET
  POINT_ZERO
  CONCENTRATION_PIKE
}

model User {
  id                  String        @id @default(uuid())
  name                String
  email               String        @unique
  password            String
  role                Role          @default(USER)
  resetToken          String?
  resetTokenExpiresAt DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  settings            UserSettings?
  routines            Routine[]
  workouts            Workout[]
  exercises           Exercise[]
}

model UserSettings {
  id                 String      @id @default(uuid())
  userId             String      @unique
  historyMode        HistoryMode @default(BY_EXERCISE)
  defaultRestSeconds Int         @default(60)
  updatedAt          DateTime    @updatedAt
  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Exercise {
  id               String            @id @default(uuid())
  name             String
  muscleGroup      String
  equipment        String?
  metricType       MetricType        @default(REPS)
  imageUrl         String?
  videoUrl         String?
  isCustom         Boolean           @default(false)
  createdBy        String?
  createdAt        DateTime          @default(now())
  creator          User?             @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  routineExercises RoutineExercise[]
  workoutSets      WorkoutSet[]
}

model Routine {
  id          String            @id @default(uuid())
  userId      String
  name        String
  description String?
  isPublic    Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises   RoutineExercise[]
  workouts    Workout[]
}

model RoutineExercise {
  id          String   @id @default(uuid())
  routineId   String
  exerciseId  String
  order       Int
  sets        Int      @default(3)
  restSeconds Int      @default(60)
  routine     Routine  @relation(fields: [routineId], references: [id], onDelete: Cascade)
  exercise    Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
}

model Workout {
  id         String       @id @default(uuid())
  userId     String
  routineId  String?
  name       String
  startedAt  DateTime     @default(now())
  finishedAt DateTime?
  notes      String?
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  routine    Routine?     @relation(fields: [routineId], references: [id], onDelete: SetNull)
  sets       WorkoutSet[]
}

model WorkoutSet {
  id         String   @id @default(uuid())
  workoutId  String
  exerciseId String
  setNumber  Int
  weight     Float?
  reps       Int?
  duration   Int?
  setType    SetType  @default(NORMAL)
  completed  Boolean  @default(false)
  workout    Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
}
